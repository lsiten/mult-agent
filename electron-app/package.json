{
  "name": "hermes-agent-electron",
  "version": "0.2.0",
  "description": "Hermes Agent Electron Desktop Application",
  "main": "dist/main.js",
  "scripts": {
    "// ──────── 开发相关 ────────": "",
    "setup:dev": "node scripts/setup-dev.js",
    "build:main": "tsc",
    "build:main:watch": "tsc --watch",
    "dev:electron": "npm run setup:dev && npm run build:main && electron .",
    "dev:watch": "concurrently -n 'TS,ELECTRON' -c 'blue,green' 'npm run build:main:watch' 'nodemon --watch dist --delay 1 --exec electron .'",
    "dev": "npm run dev:watch",
    "// ──────── 生产打包 ────────": "",
    "setup:prod": "node scripts/setup-prod.js",
    "setup:prod:optimized": "node scripts/setup-prod-optimized.js",
    "build:all": "npm run build:main && npm run setup:prod",
    "build:all:optimized": "npm run build:main && npm run setup:prod:optimized",
    "package": "npm run build:all && electron-builder",
    "package:optimized": "npm run build:all:optimized && electron-builder",
    "package:mac": "npm run build:all && electron-builder --mac",
    "package:mac:optimized": "npm run build:all:optimized && electron-builder --mac",
    "package:win": "npm run build:all && electron-builder --win",
    "package:linux": "npm run build:all && electron-builder --linux",
    "package:dir": "npm run build:all && electron-builder --dir",
    "// ──────── 测试 ────────": "",
    "test:unit": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:architecture": "bash scripts/test-new-architecture.sh",
    "// ──────── 清理 ────────": "",
    "clean": "node scripts/clean.js",
    "clean:all": "npm run clean && cd ../web && rm -rf dist",
    "// ──────── 启动 ────────": "",
    "check:web-deps": "node scripts/check-web-deps.js",
    "start": "npm run check:web-deps && npm run setup:dev && npm run build:main && electron .",
    "start:prod": "NODE_ENV=production electron ."
  },
  "keywords": [
    "electron",
    "hermes",
    "agent",
    "desktop",
    "ai"
  ],
  "author": "Nous Research",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^2.1.8",
    "concurrently": "^9.2.1",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "fs-extra": "^11.3.4",
    "glob": "^10.5.0",
    "nodemon": "^3.1.14",
    "playwright": "^1.59.1",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
